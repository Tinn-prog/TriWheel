APP_NAME=TriWheel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
# Comma-separated origins allowed for CORS (production: your Vercel URL).
# Example: https://triwheel.vercel.app,https://www.yourdomain.com
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=triwheel_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Production (Laravel Cloud): attach Object Storage and set AWS_* so uploads persist.
# FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — local dev: log (no real emails).
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@triwheel.test"
MAIL_FROM_NAME="${APP_NAME}"

# Production (Laravel Cloud) — required env vars:
# APP_KEY, DB_CONNECTION=pgsql, DB_URL=<neon pooled url>
# FRONTEND_URL=https://tri-wheel.vercel.app
# MAIL_MAILER=smtp + Brevo settings (see below)
# Run deploy commands with config:cache AFTER env is set (see scripts/laravel-cloud-deploy.sh)
# 1. Sign up at https://www.brevo.com
# 2. SMTP & API → SMTP → Create SMTP key
# 3. Set on Laravel Cloud:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your_brevo_login_email@gmail.com
# MAIL_PASSWORD=your_brevo_smtp_key
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=your_brevo_login_email@gmail.com
# MAIL_FROM_NAME=TriWheel

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
